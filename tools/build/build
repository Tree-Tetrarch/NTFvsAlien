#!/bin/sh
set -e
realdir="$(dirname $(realpath "$0"))"
cd $realdir
mkdir -p ../../data
cd ../../data
git rev-parse HEAD > revision.txt
date +"%Y-%b-%m %H:%M:%S" > compile_date.txt
cd ../_ntf_modular
printf "#define DEFINE_REVINFO_REVISION \"" >> revinfo.dm
(git rev-parse HEAD |  tr -d '\n') >> revinfo.dm
printf "\"\r\n#define DEFINE_REVINFO_COMPILE_DATE \"" >> revinfo.dm
(date +"%Y-%b-%m %H:%M:%S" |  tr -d '\n') >> revinfo.dm
printf "\"\r\n" >> revinfo.dm
cd $realdir
../bootstrap/node build.js "$@"
cd $realdir
cd ../../_ntf_modular
rm revinfo.dm
echo "//Do not edit manually" > revinfo.dm
cd $realdir
